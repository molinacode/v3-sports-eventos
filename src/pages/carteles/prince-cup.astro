---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Cartel · Demo Prince Padel Cup" description="Jornada demo Prince Padel Cup · 20 de junio">
  <main class="min-h-screen w-full flex flex-col items-center gap-6 py-8 px-4" style="background:#111;">
    <!-- Barra de acciones (no se imprime) -->
    <div class="no-print flex items-center gap-3">
      <button onclick="window.print()" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-bold text-prince-bg bg-prince-gold hover:scale-[1.03] transition">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z"/></svg>
        Imprimir / Guardar PDF
      </button>
      <a href="/carteles/ranking" class="text-white/60 hover:text-white text-sm underline">Ver cartel del Ranking</a>
    </div>

    <!-- CARTEL A4 -->
    <article class="poster relative overflow-hidden bg-prince-bg text-white" style="width:210mm;min-height:297mm;box-shadow:0 30px 80px rgba(0,0,0,0.6);">
      <!-- Fondos decorativos -->
      <div class="absolute inset-0" style="background: radial-gradient(circle at 18% 8%, rgba(255,210,63,0.20) 0%, transparent 45%), radial-gradient(circle at 85% 18%, rgba(255,46,99,0.18) 0%, transparent 45%), radial-gradient(circle at 50% 95%, rgba(0,229,255,0.12) 0%, transparent 55%);"></div>
      <div class="absolute inset-0 bg-noise opacity-[0.05] mix-blend-overlay"></div>

      <!-- Cartas decorativas -->
      <div class="absolute -right-10 top-40 opacity-90" style="transform:rotate(14deg);">
        <div class="w-40 h-56 rounded-2xl border-2 border-prince-electric/70 flex items-center justify-center" style="background:linear-gradient(135deg,#101418,#0a0a0a);box-shadow:0 20px 50px rgba(0,229,255,0.25);">
          <img src="/img/favicon.svg" class="w-20 h-20" alt="" />
        </div>
      </div>
      <div class="absolute -left-10 top-56 opacity-90" style="transform:rotate(-16deg);">
        <div class="w-36 h-52 rounded-2xl border-2 border-prince-crown/70 flex items-center justify-center" style="background:linear-gradient(135deg,#1a0d12,#0a0a0a);box-shadow:0 20px 50px rgba(255,46,99,0.25);">
          <svg width="64" height="64" viewBox="0 0 100 100"><path d="M18 38 L32 64 L50 36 L68 64 L82 38 L77 80 L23 80 Z" fill="#FFD23F"/><circle cx="18" cy="34" r="6" fill="#FF2E63"/><circle cx="50" cy="30" r="6" fill="#00E5FF"/><circle cx="82" cy="34" r="6" fill="#FFD23F"/></svg>
        </div>
      </div>

      <div class="relative h-full flex flex-col px-12 py-14">
        <!-- Cabecera -->
        <header class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <img src="/img/favicon.svg" class="w-12 h-12" alt="V3 Sports" />
            <div class="leading-tight">
              <div class="font-display uppercase tracking-wider text-sm">V3 Sports Eventos</div>
              <div class="text-prince-gold text-[11px] tracking-[0.3em] uppercase">en Club Vip Padel</div>
            </div>
          </div>
          <div class="font-gaming tracking-[0.3em] text-prince-electric text-sm border border-prince-electric/40 rounded-full px-4 py-1.5">JORNADA ESPECIAL</div>
        </header>

        <!-- Título -->
        <div class="mt-16 text-center">
          <div class="font-gaming tracking-[0.4em] text-white/70 text-lg">JUEGA CON CARTAS TIPO KING LEAGUE</div>
          <h1 class="font-gaming leading-[0.82] mt-3 text-[5.4rem]" style="background:linear-gradient(135deg,#FFD23F 0%,#FF2E63 50%,#00E5FF 100%);-webkit-background-clip:text;background-clip:text;color:transparent;">
            PRINCE<br/>PADEL CUP
          </h1>
          <p class="mt-5 text-white/80 text-xl max-w-xl mx-auto">Ven a probar una <span class="text-prince-gold font-semibold">competición diferente</span> que te enganchará.</p>
        </div>

        <!-- Fecha + hora -->
        <div class="mt-12 grid grid-cols-3 gap-5">
          <div class="rounded-2xl border border-white/15 bg-white/[0.03] p-6 text-center">
            <div class="text-prince-gold text-xs uppercase tracking-[0.25em]">Fecha</div>
            <div class="font-gaming text-5xl mt-2">20 JUN</div>
            <div class="text-white/60 text-sm mt-1">Sábado</div>
          </div>
          <div class="rounded-2xl border border-white/15 bg-white/[0.03] p-6 text-center">
            <div class="text-prince-gold text-xs uppercase tracking-[0.25em]">Horario</div>
            <div class="font-gaming text-5xl mt-2">10–12 h</div>
            <div class="text-white/60 text-sm mt-1">2 horas de juego</div>
          </div>
          <div class="rounded-2xl border border-prince-gold/40 bg-prince-gold/10 p-6 text-center">
            <div class="text-prince-gold text-xs uppercase tracking-[0.25em]">Precio</div>
            <div class="font-gaming text-5xl mt-2 text-prince-gold">13 €</div>
            <div class="text-white/60 text-sm mt-1">por jugador/a</div>
          </div>
        </div>

        <!-- Detalles -->
        <div class="mt-8 flex flex-wrap justify-center gap-3 text-sm">
          <span class="inline-flex items-center gap-2 rounded-full border border-prince-electric/40 px-4 py-2"><span class="w-2 h-2 rounded-full bg-prince-electric"></span>De 10 a 16 años · no federados</span>
          <span class="inline-flex items-center gap-2 rounded-full border border-white/20 px-4 py-2"><span class="w-2 h-2 rounded-full bg-prince-crown"></span>Mínimo 6 parejas inscritas</span>
        </div>

        <!-- Inscripciones -->
        <div class="mt-auto pt-12">
          <div class="rounded-3xl p-8 text-center" style="background:linear-gradient(135deg,#1a1208,#0a0a0a);border:1px solid rgba(255,210,63,0.35);">
            <div class="font-gaming tracking-[0.3em] text-prince-gold text-lg">INSCRÍBETE HASTA EL 18 DE JUNIO</div>
            <div class="mt-3 flex items-center justify-center gap-6 flex-wrap">
              <div class="flex items-center gap-3">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFD23F" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span class="font-display text-3xl tracking-wider">637 67 18 17</span>
              </div>
              <span class="text-white/40">·</span>
              <div class="flex items-center gap-3">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFD23F" stroke-width="2"><path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-3"/></svg>
                <span class="font-display text-2xl tracking-wider">En el Club Vip Padel</span>
              </div>
            </div>
          </div>
          <p class="text-white/40 text-xs text-center mt-5">La organización se reserva el cambio de horarios en caso necesario. Plazas limitadas por orden de inscripción.</p>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style is:global>
  @media print {
    @page { size: A4 portrait; margin: 0; }
    html, body { background: #fff !important; }
    .no-print { display: none !important; }
    .poster { box-shadow: none !important; width: 210mm !important; min-height: 297mm !important; }
    main { padding: 0 !important; background: #fff !important; }
  }
</style>
