---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Cartel · Demo Ranking Mixto" description="Jornada demo Ranking Mixto · 20 de junio">
  <main class="min-h-screen w-full flex flex-col items-center gap-6 py-8 px-4" style="background:#0b1020;">
    <!-- Barra de acciones (no se imprime) -->
    <div class="no-print flex items-center gap-3">
      <button onclick="window.print()" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-bold text-mixto-deep bg-mixto-court hover:scale-[1.03] transition">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z"/></svg>
        Imprimir / Guardar PDF
      </button>
      <a href="/carteles/prince-cup" class="text-white/60 hover:text-white text-sm underline">Ver cartel de la Prince Cup</a>
    </div>

    <!-- CARTEL A4 -->
    <article class="poster relative overflow-hidden text-white" style="width:210mm;min-height:297mm;background:#0F1B3D;box-shadow:0 30px 80px rgba(0,0,0,0.6);">
      <!-- Fondos decorativos -->
      <div class="absolute inset-0" style="background: radial-gradient(circle at 15% 10%, rgba(198,255,61,0.18) 0%, transparent 45%), radial-gradient(circle at 88% 85%, rgba(198,255,61,0.10) 0%, transparent 45%), radial-gradient(circle at 80% 12%, rgba(26,42,85,0.9) 0%, transparent 50%);"></div>
      <div class="absolute inset-0 bg-noise opacity-[0.05] mix-blend-overlay"></div>

      <!-- Pista + rotación (pozo) decorativa -->
      <svg class="absolute right-[-40px] top-44 opacity-20" width="280" height="360" viewBox="0 0 280 360" fill="none">
        <rect x="20" y="20" width="240" height="320" rx="8" stroke="#C6FF3D" stroke-width="3"/>
        <line x1="20" y1="180" x2="260" y2="180" stroke="#C6FF3D" stroke-width="3"/>
        <line x1="140" y1="20" x2="140" y2="340" stroke="#C6FF3D" stroke-width="1.5" stroke-dasharray="6 8"/>
        <path d="M70 120 A60 60 0 1 1 68 122" stroke="#C6FF3D" stroke-width="3" fill="none"/>
        <path d="M64 110 L70 124 L82 116 Z" fill="#C6FF3D"/>
      </svg>

      <div class="relative h-full flex flex-col px-12 py-14">
        <!-- Cabecera -->
        <header class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <img src="/img/favicon.svg" class="w-12 h-12" alt="V3 Sports" />
            <div class="leading-tight">
              <div class="font-display uppercase tracking-wider text-sm">V3 Sports Eventos</div>
              <div class="text-mixto-court text-[11px] tracking-[0.3em] uppercase">en Club Vip Padel</div>
            </div>
          </div>
          <div class="font-display tracking-[0.3em] text-mixto-court text-sm border border-mixto-court/40 rounded-full px-4 py-1.5">JORNADA ESPECIAL</div>
        </header>

        <!-- Título -->
        <div class="mt-16 text-center">
          <div class="font-display tracking-[0.35em] text-white/70 text-lg">PUERTAS ABIERTAS · FORMATO POZO</div>
          <h1 class="font-display uppercase leading-[0.82] mt-3 text-[6.2rem]" style="background:linear-gradient(135deg,#EAFFB0 0%,#C6FF3D 55%,#7DB400 100%);-webkit-background-clip:text;background-clip:text;color:transparent;">
            Ranking<br/>Mixto
          </h1>
          <p class="mt-5 text-white/80 text-xl max-w-xl mx-auto">Partidos rápidos tipo <span class="text-mixto-court font-semibold">pozo</span>: cambias de pista y de compañero/a cada partido. Ven a probarlo.</p>
        </div>

        <!-- Fecha + hora -->
        <div class="mt-12 grid grid-cols-3 gap-5">
          <div class="rounded-2xl border border-white/15 bg-white/[0.04] p-6 text-center">
            <div class="text-mixto-court text-xs uppercase tracking-[0.25em]">Fecha</div>
            <div class="font-display text-5xl mt-2">20 JUN</div>
            <div class="text-white/60 text-sm mt-1">Sábado</div>
          </div>
          <div class="rounded-2xl border border-white/15 bg-white/[0.04] p-6 text-center">
            <div class="text-mixto-court text-xs uppercase tracking-[0.25em]">Horario</div>
            <div class="font-display text-5xl mt-2">10–12 h</div>
            <div class="text-white/60 text-sm mt-1">2 horas de juego</div>
          </div>
          <div class="rounded-2xl border border-mixto-court/50 bg-mixto-court/10 p-6 text-center">
            <div class="text-mixto-court text-xs uppercase tracking-[0.25em]">Precio</div>
            <div class="font-display text-5xl mt-2 text-mixto-court">13 €</div>
            <div class="text-white/60 text-sm mt-1">por jugador/a</div>
          </div>
        </div>

        <!-- Detalles -->
        <div class="mt-8 flex flex-wrap justify-center gap-3 text-sm">
          <span class="inline-flex items-center gap-2 rounded-full border border-mixto-court/40 px-4 py-2"><span class="w-2 h-2 rounded-full bg-mixto-court"></span>Nivel medio / medio-avanzado</span>
          <span class="inline-flex items-center gap-2 rounded-full border border-white/20 px-4 py-2"><span class="w-2 h-2 rounded-full bg-white/60"></span>Mínimo 6 parejas inscritas</span>
        </div>

        <!-- Inscripciones -->
        <div class="mt-auto pt-12">
          <div class="rounded-3xl p-8 text-center" style="background:linear-gradient(135deg,#16224a,#0F1B3D);border:1px solid rgba(198,255,61,0.35);">
            <div class="font-display tracking-[0.3em] text-mixto-court text-lg">INSCRÍBETE HASTA EL 18 DE JUNIO</div>
            <div class="mt-3 flex items-center justify-center gap-6 flex-wrap">
              <div class="flex items-center gap-3">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#C6FF3D" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span class="font-display text-3xl tracking-wider">637 67 18 17</span>
              </div>
              <span class="text-white/40">·</span>
              <div class="flex items-center gap-3">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#C6FF3D" stroke-width="2"><path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-3"/></svg>
                <span class="font-display text-2xl tracking-wider">En el Club Vip Padel</span>
              </div>
            </div>
          </div>
          <p class="text-white/40 text-xs text-center mt-5">La organización se reserva el cambio de horarios en caso necesario. Plazas limitadas por orden de inscripción.</p>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style is:global>
  @media print {
    @page { size: A4 portrait; margin: 0; }
    html, body { background: #fff !important; }
    .no-print { display: none !important; }
    .poster { box-shadow: none !important; width: 210mm !important; min-height: 297mm !important; }
    main { padding: 0 !important; background: #fff !important; }
  }
</style>
