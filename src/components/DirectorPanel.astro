---
import revenueData from "../data/revenue.json";
import { computeRevenue } from "../scripts/revenue";
import RevenueCalculator from "./RevenueCalculator.astro";

// ─────────────────────────────────────────────────────────────
// INFO FINANCIERA CAPADA.
// Pon esto en `true` para volver a mostrar al cliente el KPI de
// ingresos previstos y la calculadora interactiva (sliders +
// escenarios pesimista/realista/optimista).
//
// SEGURIDAD: con el flag en `false`, el componente <RevenueCalculator/>
// no se renderiza, por lo que Astro NO incluye ni las cifras ni la
// lógica de cálculo en el JavaScript público (no son inspeccionables
// desde el navegador). Las cifras solo se calculan en build (servidor).
// ─────────────────────────────────────────────────────────────
const SHOW_FINANCIALS = false;

// Solo se usa (en build, lado servidor) para el KPI de ingresos cuando el flag está activo.
const realResult = SHOW_FINANCIALS
  ? computeRevenue(revenueData.scenarios.realista as any)
  : { total: 0 };
---

<section id="panel" class="relative py-20 sm:py-28 border-y border-club-ink/10 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-club-bg via-[#0a100c] to-club-bg"></div>
  <div class="absolute inset-0 -z-10 opacity-[0.06] mix-blend-overlay bg-noise"></div>

  <div class="container-padel">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div>
        <div class="eyebrow flex items-center gap-3">
          <span class="inline-flex w-2 h-2 rounded-full bg-club-gold animate-pulse"></span>
          Lo que aporta al club
        </div>
        <h2 class="title-display text-5xl sm:text-7xl mt-3">El programa,<br/>en <span class="text-club-gold">datos</span>.</h2>
      </div>
      <p class="text-club-ink/70 max-w-md">Actividad garantizada durante toda la temporada: jornadas fijas, ocupación de pistas y captación de nuevos jugadores para el club.</p>
    </div>

    <!-- KPIs -->
    <div class={`grid grid-cols-1 sm:grid-cols-3 ${SHOW_FINANCIALS ? "lg:grid-cols-4" : "lg:grid-cols-3"} gap-3 sm:gap-5 mb-10`}>
      {SHOW_FINANCIALS && (
        <div class="card-surface p-5 sm:p-6 reveal">
          <div class="text-club-gold text-xs uppercase tracking-[0.25em]">Ingresos / temporada</div>
          <div class="font-display text-4xl sm:text-5xl mt-2 text-club-ink" data-counter data-target={realResult.total} data-prefix="" data-suffix=" €">0 €</div>
          <div class="text-club-ink/50 text-xs mt-2">Escenario realista · 12 jornadas</div>
        </div>
      )}
      <div class="card-surface p-5 sm:p-6 reveal">
        <div class="text-club-gold text-xs uppercase tracking-[0.25em]">Jornadas Sept-May</div>
        <div class="font-display text-4xl sm:text-5xl mt-2 text-club-ink" data-counter data-target="12" data-suffix="">0</div>
        <div class="text-club-ink/50 text-xs mt-2">Cada 3 semanas, sábados</div>
      </div>
      <div class="card-surface p-5 sm:p-6 reveal">
        <div class="text-club-gold text-xs uppercase tracking-[0.25em]">Horas-pista ocupadas</div>
        <div class="font-display text-4xl sm:text-5xl mt-2 text-club-ink" data-counter data-target={revenueData.extraKPIs.occupancyHoursPerSeason} data-suffix=" h">0 h</div>
        <div class="text-club-ink/50 text-xs mt-2">Estimación temporada completa</div>
      </div>
      <div class="card-surface p-5 sm:p-6 reveal">
        <div class="text-club-gold text-xs uppercase tracking-[0.25em]">Jugadores nuevos</div>
        <div class="font-display text-4xl sm:text-5xl mt-2 text-club-ink" data-counter data-target={revenueData.extraKPIs.newPlayersExpected} data-suffix="+">0+</div>
        <div class="text-club-ink/50 text-xs mt-2">No socios captados por los eventos</div>
      </div>
    </div>

    <!-- CALCULADORA DE INGRESOS: aislada en su propio componente.
         Solo se renderiza (y solo entonces su JS llega al navegador) si SHOW_FINANCIALS. -->
    {SHOW_FINANCIALS && <RevenueCalculator />}
  </div>
</section>

<script>
  import { gsap } from "gsap";

  // Formateador local: evita importar revenue.ts (datos sensibles) en el bundle público.
  const formatEuro = (n: number) =>
    new Intl.NumberFormat("es-ES", { style: "currency", currency: "EUR", maximumFractionDigits: 0 }).format(n);

  // Contadores animados (jornadas, horas-pista, jugadores nuevos y, si procede, ingresos).
  const counters = document.querySelectorAll<HTMLElement>("[data-counter]");
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = Number(el.dataset.target);
        const suffix = el.dataset.suffix || "";
        const isMoney = suffix.trim() === "€";
        const obj = { v: 0 };
        gsap.to(obj, {
          v: target,
          duration: 1.6,
          ease: "power2.out",
          onUpdate: () => {
            const val = Math.floor(obj.v);
            el.textContent = isMoney ? formatEuro(val) : `${val}${suffix}`;
          },
        });
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.4 });
  counters.forEach((c) => observer.observe(c));
</script>
