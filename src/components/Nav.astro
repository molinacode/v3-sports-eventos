---
import eventsData from "../data/events.json";
import Logo from "./Logo.astro";
const { events, season } = eventsData;
const current = Astro.url.pathname;
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-club-bg/75 border-b border-club-ink/10">
  <div class="container-padel flex items-center justify-between gap-4 py-3 sm:py-4">
    <a href="/" class="flex items-center gap-3 group text-club-ink group-hover:text-club-gold transition-colors">
      <Logo variant="monogram" palette="site" class="h-10" />
      <div class="leading-tight">
        <div class="font-display uppercase tracking-wider text-club-ink text-sm sm:text-base">V3 Sports Eventos</div>
        <div class="text-club-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase">Temporada {season}</div>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      <a href="/" class={`px-4 py-2 rounded-full text-sm font-semibold transition ${current === "/" ? "bg-club-ink/10 text-club-ink" : "text-club-ink/70 hover:text-club-ink"}`}>Inicio</a>
      {events.map((ev) => (
        <a href={`/eventos/${ev.slug}`} class={`px-4 py-2 rounded-full text-sm font-semibold transition ${current.includes(ev.slug) ? "bg-club-ink/10 text-club-ink" : "text-club-ink/70 hover:text-club-ink"}`}>
          {ev.name}
        </a>
      ))}
    </nav>

    <a href="/#calendario" class="hidden sm:inline-flex btn-primary text-sm py-2 px-4">Ver calendario</a>

    <button id="navToggle" class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-full border border-club-ink/20 text-club-ink" aria-label="Abrir menú">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <div id="mobileMenu" class="md:hidden hidden border-t border-club-ink/10">
    <div class="container-padel py-3 flex flex-col gap-1">
      <a href="/" class="px-3 py-3 rounded-lg hover:bg-club-ink/5">Inicio</a>
      {events.map((ev) => (
        <a href={`/eventos/${ev.slug}`} class="px-3 py-3 rounded-lg hover:bg-club-ink/5">{ev.name}</a>
      ))}
      <a href="/#calendario" class="btn-primary justify-center mt-2">Ver calendario</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("navToggle");
  const menu = document.getElementById("mobileMenu");
  btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
</script>
