---
import eventsData from "../data/events.json";
const { events } = eventsData;
---

<section class="container-padel py-20 sm:py-28">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
    <div>
      <div class="eyebrow">Los tres eventos</div>
      <h2 class="title-display text-5xl sm:text-7xl mt-3">Un programa<br/>para todo el club.</h2>
    </div>
    <p class="text-club-ink/70 max-w-md">Cada evento ataca un público distinto. Juntos llenan la pista durante 12 jornadas y 9 meses. Pulsa para entrar.</p>
  </div>

  <div class="grid lg:grid-cols-3 gap-5 lg:gap-6">
    {events.map((ev, idx) => (
      <a
        href={`/eventos/${ev.slug}`}
        class="reveal group relative isolate overflow-hidden rounded-3xl border border-club-ink/10 hover-lift"
        style={`background:
          linear-gradient(155deg, ${ev.color} 0%, #000 110%);`}
      >
        <div class="absolute inset-0 bg-noise opacity-[0.08] mix-blend-overlay"></div>

        <div class="relative p-7 sm:p-9 flex flex-col h-full min-h-[28rem]">
          <div class="flex items-center justify-between">
            <span class="font-display tracking-[0.3em] text-xs opacity-70" style={`color: ${ev.accent};`}>0{idx + 1} / 03</span>
            <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full border" style={`color: ${ev.accent}; border-color: ${ev.accent}80;`}>{ev.subtitle.split(" · ").pop()}</span>
          </div>

          <div class="mt-auto">
            <h3 class="font-display uppercase text-4xl sm:text-5xl leading-[0.9] text-white">{ev.name}</h3>
            <p class="mt-3 text-white/75 text-sm sm:text-base max-w-xs">{ev.headline}</p>

            <ul class="mt-6 space-y-1.5 text-sm text-white/80">
              {ev.format.slice(0, 3).map((f) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: ${ev.accent};`}></span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>

            <div class="mt-8 flex items-center justify-between">
              <span class="text-xs uppercase tracking-wider opacity-60">{ev.frequency}</span>
              <span class="inline-flex items-center gap-2 font-semibold group-hover:gap-3 transition-all" style={`color: ${ev.accent};`}>
                Descubrir
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
