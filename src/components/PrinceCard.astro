---
import CardIcon from "./CardIcon.astro";

interface Card {
  id: string;
  name: string;
  rarity: string;
  rarityLevel: number;
  icon: string;
  tagline: string;
  description: string;
}

interface Props {
  card: Card;
  index?: number;
  size?: "sm" | "md" | "lg";
}

const { card, index = 0, size = "md" } = Astro.props;

const rarityColors: Record<number, { primary: string; glow: string; label: string }> = {
  1: { primary: "#9BC9FF", glow: "rgba(155,201,255,0.35)", label: "COMÚN" },
  2: { primary: "#00E5FF", glow: "rgba(0,229,255,0.5)",   label: "RARA" },
  3: { primary: "#FF2E63", glow: "rgba(255,46,99,0.55)",  label: "ÉPICA" },
  4: { primary: "#FFD23F", glow: "rgba(255,210,63,0.65)", label: "LEGENDARIA" },
};
const r = rarityColors[card.rarityLevel] ?? rarityColors[1];

const sizes = {
  sm: "w-44 h-64 sm:w-48 sm:h-72",
  md: "w-60 h-80 sm:w-64 sm:h-96",
  lg: "w-72 h-[26rem] sm:w-80 sm:h-[28rem]",
};
const iconSizes = { sm: 56, md: 80, lg: 110 };
---

<div
  class={`prince-card card-3d ${sizes[size]} relative cursor-pointer select-none`}
  data-card-id={card.id}
  data-rarity={card.rarityLevel}
  style={`--rarity: ${r.primary}; --rarity-glow: ${r.glow}; animation-delay: ${index * 0.06}s;`}
>
  <div class="card-3d-inner relative w-full h-full rounded-[18px] shadow-2xl" style="box-shadow: 0 30px 60px -20px var(--rarity-glow);">
    <!-- ANVERSO -->
    <div class="card-face card-front holo-bg overflow-hidden">
      <!-- Border decorativo -->
      <div class="absolute inset-0 rounded-[18px] pointer-events-none" style="box-shadow: inset 0 0 0 2px var(--rarity), inset 0 0 18px rgba(255,255,255,0.06);"></div>
      <div class="absolute inset-[6px] rounded-[14px] pointer-events-none border border-prince-gold/40"></div>

      <!-- Pattern decorativo de fondo -->
      <svg class="absolute inset-0 w-full h-full opacity-20 mix-blend-overlay" viewBox="0 0 200 280" preserveAspectRatio="none">
        <defs>
          <pattern id={`p-${card.id}`} width="14" height="14" patternUnits="userSpaceOnUse">
            <path d="M0 7 L7 0 L14 7 L7 14 Z" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="200" height="280" fill={`url(#p-${card.id})`}/>
      </svg>

      <!-- Header (rareza + número) -->
      <div class="absolute top-3 left-3 right-3 flex items-center justify-between">
        <span class="font-display tracking-[0.25em] text-[10px] sm:text-[11px] px-2 py-1 rounded-md backdrop-blur-sm border" style={`color: ${r.primary}; border-color: ${r.primary}80; background: ${r.primary}15;`}>{r.label}</span>
        <span class="font-display text-prince-gold text-xs sm:text-sm tracking-wider">P · {String(card.rarityLevel)}</span>
      </div>

      <!-- Icono central -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="relative">
          <div class="absolute inset-0 blur-2xl opacity-60" style={`background: radial-gradient(circle, ${r.primary} 0%, transparent 70%);`}></div>
          <div class="relative card-icon-src">
            <CardIcon name={card.icon} size={iconSizes[size]} />
          </div>
        </div>
      </div>

      <!-- Nombre y tagline -->
      <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-5 text-center bg-gradient-to-t from-black/90 to-transparent">
        <div class="font-gaming text-white text-2xl sm:text-3xl tracking-wider leading-none">{card.name}</div>
        <div class="text-prince-gold text-[10px] sm:text-xs mt-1.5 uppercase tracking-wider italic">{card.tagline}</div>
      </div>

      <!-- Shine -->
      <div class="card-shine absolute inset-0 pointer-events-none"></div>
    </div>

    <!-- REVERSO -->
    <div class="card-face card-back bg-prince-bg overflow-hidden">
      <div class="absolute inset-0 rounded-[18px] pointer-events-none" style="box-shadow: inset 0 0 0 2px var(--rarity);"></div>
      <div class="absolute inset-[6px] rounded-[14px] pointer-events-none border border-prince-gold/30"></div>

      <!-- Watermark corona -->
      <svg class="absolute -top-8 -right-8 w-40 h-40 opacity-10" viewBox="0 0 100 100"><path d="M20 35 L30 60 L50 35 L70 60 L80 35 L75 75 L25 75 Z" fill="#FFD23F"/></svg>

      <div class="relative h-full flex flex-col p-5 sm:p-6 text-white">
        <div class="flex items-center gap-2">
          <span class="font-gaming text-prince-gold text-xl tracking-wider">PRINCE</span>
          <span class="font-gaming text-prince-crown text-xl tracking-wider">CUP</span>
        </div>

        <div class="mt-4 pt-4 border-t border-white/10">
          <div class="font-display uppercase text-xl sm:text-2xl leading-tight">{card.name}</div>
          <div class="text-prince-electric text-[10px] sm:text-xs mt-1 tracking-widest uppercase">{r.label}</div>
        </div>

        <p class="mt-4 text-white/85 text-sm leading-relaxed">{card.description}</p>

        <div class="mt-auto pt-4 border-t border-white/10 flex items-center justify-between text-[10px] uppercase tracking-widest text-white/40">
          <span>1 carta / partido</span>
          <span>Aleatoria</span>
        </div>
      </div>
    </div>
  </div>
</div>
