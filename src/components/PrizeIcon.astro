---
interface Props {
  name: string;
  color?: string;
  size?: number;
}
const { name, color = "currentColor", size = 28 } = Astro.props;
---

<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
  {name === "trophy" && (
    <>
      <path d="M6 9V6h12v3a6 6 0 0 1-12 0z"/>
      <path d="M6 6H4a2 2 0 0 0 2 2"/>
      <path d="M18 6h2a2 2 0 0 1-2 2"/>
      <path d="M9 18h6"/>
      <path d="M12 15v3"/>
      <path d="M9 21h6"/>
    </>
  )}
  {name === "clock" && (
    <>
      <circle cx="12" cy="12" r="9"/>
      <path d="M12 7v5l3 2"/>
    </>
  )}
  {name === "sparkles" && (
    <>
      <path d="M12 3l1.8 4.5L18 9l-4.2 1.5L12 15l-1.8-4.5L6 9l4.2-1.5L12 3z"/>
      <path d="M18 16l.9 2.2L21 19l-2.1.8L18 22l-.9-2.2L15 19l2.1-.8L18 16z"/>
    </>
  )}
  {name === "heart" && (
    <path d="M12 21s-7-4.6-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 5.4-7 10-7 10z"/>
  )}
  {name === "gift" && (
    <>
      <rect x="3" y="8" width="18" height="13" rx="1"/>
      <path d="M12 8v13M3 12h18M7 8a3 3 0 0 1 0-6c3 0 5 6 5 6s2-6 5-6a3 3 0 0 1 0 6"/>
    </>
  )}
  {name === "flame" && (
    <path d="M12 2s4 4 4 8a4 4 0 0 1-8 0c0-1 .5-2 1-3-1 .5-3 2-3 5a6 6 0 0 0 12 0c0-5-6-10-6-10z"/>
  )}
  {name === "users" && (
    <>
      <circle cx="9" cy="8" r="3"/>
      <path d="M3 20c0-3 3-5 6-5s6 2 6 5"/>
      <circle cx="17" cy="9" r="2.5"/>
      <path d="M15 20c0-2 2-3.5 4-3.5"/>
    </>
  )}
  {name === "calendar" && (
    <>
      <rect x="3" y="5" width="18" height="16" rx="2"/>
      <path d="M3 10h18M8 3v4M16 3v4"/>
    </>
  )}
</svg>
